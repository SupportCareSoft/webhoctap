        .ex-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(85px, 1fr)); gap: 10px; margin-bottom: 30px; }
        .ex-card { padding: 15px 5px; border-radius: 12px; text-align: center; cursor: pointer; border: 2px solid #eee; font-size: 13px; font-weight: bold; background: #fff; }
        .status-correct { border-color: var(--green); background: #e8f5e9; color: #1b5e20; }
        .status-wrong { border-color: #e74c3c; background: #fdedec; color: #78281f; }
        #quiz-overlay { display: none; position: fixed; top:0; left:0; width:100%; height:100%; background: rgba(0,0,0,0.8); z-index: 2000; justify-content: center; align-items: center; padding: 10px; }
        .quiz-box {
            background: white;
            width: 100%;
            max-width: 560px;
            max-height: 90vh;
            padding: 20px 25px;
            border-radius: 30px;
            text-align: center;
            overflow-y: auto;
            position: relative;
        }
        .q-text-main { font-size: 20px; color: #444; margin-bottom: 15px; font-weight: 500; line-height: 1.5; }
        .highlight-word { font-size: 48px; font-weight: 900; color: var(--primary); display: block; margin: 5px 0; line-height: 1.2; }
        .btn-opt { display: block; width: 100%; padding: 12px; margin: 8px 0; border: 2px solid #f0f0f0; border-radius: 15px; cursor: pointer; font-weight: bold; font-size: 22px; color: #333; transition: 0.2s; background: #fff; }
