function getQuestion(tid, n) {
    const list = QUESTION_BANK[tid] || [];
    let shuffle = JSON.parse(localStorage.getItem('shuffle_' + tid) || '[]');
    let idx = (shuffle.length > 0 && shuffle[n-1] !== undefined) ? shuffle[n-1] : (n - 1);
    const q = list[idx % list.length];
    if (!q) return { html: `Bài số ${n}`, opts: ['Đúng', 'Sai'], ans: 'Đúng', type: 'text' };
    return {
        html: q.html,
        opts: q.opts,
        ans: q.ans,
        type: q.type || 'text'
    };
}

async function setGrade(g) {
    const sessionID = localStorage.getItem('session_' + g) || '1';
    const snap = await db.ref('tv_history').orderByChild('kidName').equalTo(kidName).once('value');
    let history = {};
    snap.forEach(c => { if (c.val().session === sessionID) history[c.val().exID] = c.val().result; });

    document.getElementById('grade-title').innerText = curriculum[g].name;
    const area = document.getElementById('content-area');
    area.innerHTML = curriculum[g].topics.map(t => {
        let done = 0;
        const cards = Array.from({ length: t.count }, (_, i) => {
            const id = `${t.id}_${i+1}`;
            if (history[id] === 'Correct') done++;
            const st = history[id] === 'Correct' ? 'status-correct' : (history[id] === 'Wrong' ? 'status-wrong' : '');
            return `<div class="ex-card ${st}" onclick="startQuiz('${t.id}',${i+1},'${g}')">Bài ${i+1}</div>`;
        }).join('');
        return `
            <div class="topic-header">
                <div>
                    <h3 style="margin:0; font-size:18px">${t.title}</h3>
                    <div class="topic-note">${t.note || ''}</div>
                </div>
                ${done === t.count ? `<button class="btn-reset" onclick="resetTopic('${t.id}','${g}')">Đổi bài mới 🔄</button>` : ''}
            </div>
            <div class="ex-grid">${cards}</div>
        `;
    }).join('');
}

function startQuiz(tid, n, g) {
    const data = getQuestion(tid, n);
    document.getElementById('quiz-overlay').style.display = 'flex';
    document.getElementById('q-container').innerHTML = data.html;
    const box = document.getElementById('q-opts');
    box.innerHTML = '';

    [...new Set([data.ans, ...data.opts])].sort(() => Math.random() - 0.5).forEach(o => {
        const btn = document.createElement('button');
        btn.className = 'btn-opt';
        if (data.type === 'symbol' && symbolMap[o]) {
            btn.innerHTML = `<span class="symbol-style">${symbolMap[o]}</span>`;
        } else {
            btn.innerText = o;
        }
        btn.onclick = async () => {
            await db.ref('tv_history').push({
                kidName,
                exID: `${tid}_${n}`,
                result: (o === data.ans ? 'Correct' : 'Wrong'),
                session: (localStorage.getItem('session_' + g) || '1')
            });
            closeQuiz();
            setGrade(g);
        };
        box.appendChild(btn);
    });
}

function resetTopic(tid, g) {
    localStorage.setItem('session_' + g, Date.now().toString());
    let count = curriculum[g].topics.find(x => x.id === tid).count;
    localStorage.setItem('shuffle_' + tid, JSON.stringify(Array.from({ length: count }, (_, i) => i).sort(() => Math.random() - 0.5)));
    location.reload();
}

function closeQuiz() {
    document.getElementById('quiz-overlay').style.display = 'none';
}

function setActiveMenu(g) {
    localStorage.setItem('currentGrade', g);
    document.querySelectorAll('.grade-item').forEach(i => i.classList.remove('active'));
    if (document.getElementById('btn-' + g)) document.getElementById('btn-' + g).classList.add('active');
    setGrade(g);
}

window.onload = () => {
    document.getElementById('display-name').innerText = kidName;
    const menu = document.getElementById('grade-menu');
    menu.innerHTML = Object.keys(curriculum).map(k => `<div class="grade-item" id="btn-${k}" onclick="setActiveMenu('${k}')">${curriculum[k].name}</div>`).join('');
    setActiveMenu(localStorage.getItem('currentGrade') || '5t');
};
